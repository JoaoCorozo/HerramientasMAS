# Vercel / producción — dejar NEXT_PUBLIC_API_URL vacío para usar proxy /api

# Vacío = peticiones a /api del mismo dominio (recomendado)
NEXT_PUBLIC_API_URL=

# Solo en Vercel (variable de servidor, no NEXT_PUBLIC_): URL del backend Render/Railway
BACKEND_URL=https://tu-api.onrender.com

# Opcional: si subes Excels muy grandes (>4 MB), apunta directo al API y activa CROSS_SITE_AUTH en el backend
# NEXT_PUBLIC_API_URL=https://tu-api.onrender.com
