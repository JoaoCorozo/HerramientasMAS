# PUBLIC_FRONTEND_URL=https://tu-app.vercel.app
# MATRIZ_CURSOS_PATH=/app/MATRIZ_CURSOS_BEX.xlsx
# CROSS_SITE_AUTH=false

APP_ENCRYPTION_KEY=
MAX_UPLOAD_BYTES=20971520
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_SECONDS=300
