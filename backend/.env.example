# Copiar a backend/.env (no subir a git)

# --- Local ---
APP_ENV=development
DATABASE_URL=sqlite:///./users.db
JWT_SECRET_KEY=dev-local-cambiar-en-produccion
BOOTSTRAP_ADMIN_PASSWORD=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Nube (sync scripts) ---
POSTGRES_DATABASE_URL=postgresql://usuario:password@host/neondb?sslmode=require

# --- Producción Render (mismas claves en el panel Render) ---
# APP_ENV=production
# DATABASE_URL=postgresql://...@neon.tech/neondb?sslmode=require
# JWT_SECRET_KEY=
# APP_ENCRYPTION_KEY=
